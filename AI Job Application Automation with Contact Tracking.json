    },
    {
      "parameters": {
        "jsCode": "// Normalize all job data from RSS feeds and API sources to consistent format\nconst jobs = [];\n\n// Loop through all input items\nfor (const item of $input.all()) {\n  const data = item.json;\n  \n  // Check if this is already-parsed API job data (has jobs array)\n  if (data.jobs && Array.isArray(data.jobs)) {\n    // Already normalized from API parser - just add to jobs array\n    jobs.push(...data.jobs);\n  }\n  // Check if this is RSS feed item (has title, link, etc.)\n  else if (data.title || data.link) {\n    // Parse RSS feed structure\n    const job = {\n      title: data.title || '',\n      company: data['company'] || data['dc:creator'] || data['author'] || 'Unknown',\n      location: data['location'] || data['indeed:location'] || data['geo:lat'] ? 'Location Available' : 'Not specified',\n      jobLink: data.link || data.guid || '',\n      source: data.source || 'RSS Feed'\n    };\n    jobs.push(job);\n  }\n  // Fallback for other formats\n  else {\n    const job = {\n      title: data.title || data.name || data.position || '',\n      company: data.company || data.company_name || 'Unknown',\n      location: data.location || 'Not specified',\n      jobLink: data.jobLink || data.url || data.link || '',\n      source: data.source || 'Unknown'\n    };\n    jobs.push(job);\n  }\n}\n\n// Return array with jobs field containing all normalized jobs\nreturn [{ json: { jobs } }];"
      },
      "id": "644ba833-b45b-4fc1-91d1-c7485657eff0",
      "name": "Normalize All Job Data",
      "type": "n8n-nodes-base.code",
