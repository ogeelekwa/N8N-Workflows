    {
      "parameters": {
        "jsCode": "// Parse different API response formats and normalize to consistent structure\nconst jobs = [];\n\n// Loop through all input items from different API sources\nfor (const item of $input.all()) {\n  const data = item.json;\n  \n  // Detect source and parse accordingly\n  \n  // Adzuna API format\n  if (data.results && Array.isArray(data.results)) {\n    for (const job of data.results) {\n      jobs.push({\n        title: job.title || '',\n        company: job.company?.display_name || 'Unknown',\n        location: job.location?.display_name || 'Not specified',\n        jobLink: job.redirect_url || '',\n        source: 'Adzuna'\n      });\n    }\n  }\n  \n  // RemoteOK API format (array of jobs)\n  else if (Array.isArray(data)) {\n    for (const job of data) {\n      if (job.id) { // Skip the first metadata item\n        jobs.push({\n          title: job.position || '',\n          company: job.company || 'Unknown',\n          location: job.location || 'Remote',\n          jobLink: `https://remoteok.com/remote-jobs/${job.id}` || '',\n          source: 'RemoteOK'\n        });\n      }\n    }\n  }\n  \n  // The Muse API format\n  else if (data.results && Array.isArray(data.results)) {\n    for (const job of data.results) {\n      jobs.push({\n        title: job.name || '',\n        company: job.company?.name || 'Unknown',\n        location: job.locations?.[0]?.name || 'Not specified',\n        jobLink: job.refs?.landing_page || '',\n        source: 'The Muse'\n      });\n    }\n  }\n  \n  // Generic fallback for unknown formats\n  else {\n    jobs.push({\n      title: data.title || data.name || data.position || '',\n      company: data.company || data.company_name || 'Unknown',\n      location: data.location || 'Not specified',\n      jobLink: data.url || data.link || data.job_url || '',\n      source: 'API'\n    });\n  }\n}\n\n// Return array with jobs field containing all parsed jobs\nreturn [{ json: { jobs } }];"
      },
